# Open WebUI Backend (innerhalb des Docker-Netzwerks erreichbar).
# Default passt, wenn der Container `open-webui` heißt.
UPSTREAM=http://open-webui:8080

# --- Nur für docker-compose.traefik.yml nötig ---

# Domain unter der Open WebUI per Traefik erreichbar ist.
DOMAIN=your-domain.example.com

# Name des Docker-Netzwerks, in dem Traefik die Container findet.
TRAEFIK_NETWORK=shared-network
